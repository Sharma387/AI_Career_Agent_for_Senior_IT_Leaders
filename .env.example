NVIDIA_API_KEY=your-nvidia-nim-key-here
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.1-8b-instruct

ANTHROPIC_API_KEY=your-anthropic-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-20250514

OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b

LLM_PROVIDER=anthropic

EMBEDDING_MODEL=all-MiniLM-L6-v2
DEBUG=true

# Seek.co.nz Scraping Configuration
SEEK_SCRAPING_ENABLED=true
SEEK_DEFAULT_KEYWORDS=
SEEK_DEFAULT_LOCATION=New Zealand
SEEK_CHROME_PROFILE_PATH=
SEEK_HEADLESS=true
SEEK_MAX_PAGES_PER_SEARCH=3
SEEK_REQUEST_DELAY_MIN=2.0
SEEK_REQUEST_DELAY_MAX=5.0
SEEK_DAILY_SCRAPE_HOUR=7
SEEK_DAILY_SCRAPE_MINUTE=0
SEEK_ROLE_PRESETS=project-manager,sr-project-manager,it-manager,engineering-manager,it-director,cto

# LinkedIn Extension Configuration
LINKEDIN_EXTENSION_ENABLED=true
